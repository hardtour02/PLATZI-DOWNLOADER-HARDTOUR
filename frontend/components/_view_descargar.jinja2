<section id="view-descargar" class="view-section">
            <div class="mb-10 flex flex-col md:flex-row gap-4 items-center max-w-4xl">
                <div class="relative flex-1 w-full group">
                    <i data-lucide="link"
                        class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500 group-focus-within:text-sky-400 transition-colors"></i>
                    <input type="text" id="courseUrl" placeholder="Pega la URL del curso de Platzi aquí..."
                        class="w-full bg-[#121212] border border-white/10 rounded-xl py-3.5 pl-11 pr-4 text-sm font-medium text-white placeholder-slate-600 focus:outline-none focus:border-sky-500/50 focus:shadow-[0_0_15px_rgba(56,189,248,0.1)] transition-all">
                </div>
                <button onclick="startDownload()"
                    class="bg-[#00f2a1] hover:brightness-110 text-black font-extrabold px-10 py-3.5 h-full rounded-xl transition text-sm shadow-[0_10px_20px_-10px_rgba(0,242,161,0.3)] flex items-center gap-2 whitespace-nowrap">
                    <i data-lucide="download" class="w-4 h-4"></i>
                    Descargar
                </button>
            </div>

            <!-- Active download progress -->
            <div id="activeProgress"
                class="hidden bg-[#1a1a1a] border border-[#00f2a1]/20 rounded-2xl p-8 mb-10 shadow-2xl overflow-hidden relative">
                <div id="progressError"
                    class="hidden bg-red-500/10 border border-red-500/20 text-red-400 text-xs p-4 rounded-xl mb-6 flex items-center gap-3">
                    <i data-lucide="alert-circle" class="w-5 h-5"></i>
                    <span id="progressErrorMsg"></span>
                </div>
                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h3 class="font-black flex items-center gap-3 text-lg">
                            <span id="pulseDot" class="w-3 h-3 rounded-full bg-[#00f2a1] animate-pulse"></span>
                            <span id="downloadStatusText">Descargando Contenido</span>
                        </h3>
                        <p id="currentCourseTitleLive" class="text-slate-400 text-sm mt-1"></p>
                    </div>
                    <span id="syllabusCount"
                        class="bg-white/5 px-3 py-1 rounded-full text-xs text-slate-500 font-bold border border-white/10"></span>
                </div>
                <div id="syllabusList" class="space-y-3 max-h-[500px] overflow-y-auto scr pr-2"></div>
            </div>

            <div id="syncShortcut"
                class="hidden bg-sky-500/5 border border-sky-500/10 rounded-2xl p-6 flex items-center justify-between">
                <div>
                    <h4 class="font-bold text-sky-400 mb-1">Cursos Listos para Drive</h4>
                    <p class="text-xs text-slate-500">Tienes cursos descargados que no han sido sincronizados.</p>
                </div>
                <button onclick="switchView('drive')"
                    class="bg-sky-500 hover:bg-sky-400 text-white text-xs font-bold px-4 py-2 rounded-lg transition">Ir
                    a Drive</button>
            </div>
        </section>