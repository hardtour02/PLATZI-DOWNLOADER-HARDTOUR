<section id="view-drive" class="view-section pt-6">
            <header class="flex justify-between items-end mb-8 px-2">
                <div>
                    <h2 class="text-3xl font-black italic uppercase tracking-tighter">Sincronización Cloud</h2>
                    <p class="text-slate-500 text-sm mt-1">Gestión de respaldo y compartición en Google Drive.</p>
                </div>
                <button onclick="syncRemoteDrive()"
                    class="flex items-center gap-2 px-5 py-2.5 bg-sky-500/10 hover:bg-sky-500/20 text-sky-400 rounded-xl text-xs font-bold border border-sky-500/20 transition group">
                    <i data-lucide="refresh-cw"
                        class="w-4 h-4 group-hover:rotate-180 transition-transform duration-500"></i>
                    Sincronizar con Drive
                </button>
            </header>

            <div id="driveContent" class="hidden">
                <!-- Action Bar -->
                <div id="driveActionBar"
                    class="hidden sticky top-4 z-10 bg-[#1a1a1a]/95 backdrop-blur-md border border-white/10 rounded-2xl p-4 mb-8 flex flex-wrap items-center justify-between gap-4 shadow-xl">
                    <div class="flex items-center gap-5">
                        <span id="driveSelectedCount" class="text-sm font-black text-sky-400"></span>
                        <div class="flex gap-3">
                            <button onclick="driveSelectAll()"
                                class="text-[10px] uppercase tracking-wider font-bold text-slate-500 hover:text-white transition">Todos</button>
                            <button onclick="driveSelectNone()"
                                class="text-[10px] uppercase tracking-wider font-bold text-slate-500 hover:text-white transition">Ninguno</button>
                        </div>
                    </div>
                    <div class="flex items-center gap-6">
                        <label class="flex items-center gap-3 text-xs text-slate-400 cursor-pointer select-none">
                            <input type="checkbox" id="driveShareToggle" class="accent-sky-500 w-4 h-4 rounded">
                            <span class="font-semibold">Sincronización Pública</span>
                        </label>
                        <button onclick="startDriveSync()"
                            class="bg-sky-500 hover:bg-sky-400 text-white font-black px-6 py-3 rounded-xl text-xs transition flex items-center gap-2 shadow-lg shadow-sky-500/10">
                            <i data-lucide="cloud-upload" class="w-4 h-4"></i> Iniciar Sincronización
                        </button>
                    </div>
                </div>

                <!-- Course Table -->
                <div id="driveCourseGrid" class="mb-12"></div>
                <!-- Upload Progress -->
                <div id="driveProgressPanel" class="hidden space-y-4 mb-12"></div>
            </div>
        </section>