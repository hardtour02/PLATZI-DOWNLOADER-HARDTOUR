<section id="view-tracking" class="view-section hidden">
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end mb-10 gap-6">
        <div>
            <h2 class="text-3xl font-heading font-black mb-2 text-white">Tracking de Avance</h2>
            <p class="text-[var(--text-secondary)] text-sm font-medium">Estadísticas y progreso detallado de tus cursos.</p>
        </div>
    </div>

    <!-- KPI Metrics (Repeated from courses) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
        <div class="glass p-6 rounded-[var(--radius-3xl)] border-white/5 relative overflow-hidden group">
            <div class="absolute -bottom-6 -right-4 font-black text-8xl text-white opacity-[0.03] group-hover:opacity-[0.08] transition-opacity duration-500 pointer-events-none select-none">01</div>
            <div class="flex items-center justify-between mb-4 relative z-10">
                <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-[var(--text-muted)] group-hover:text-white group-hover:bg-white/10 transition-all">
                    <i data-lucide="library" class="w-5 h-5"></i>
                </div>
                <span class="text-[9px] font-black text-[var(--text-muted)] uppercase tracking-widest">Biblioteca</span>
            </div>
            <h3 id="tracking-metric-total" class="text-3xl font-black text-white relative z-10">--</h3>
            <div class="mt-4 h-1 w-12 bg-white/10 rounded-full group-hover:w-full transition-all duration-700 relative z-10"></div>
        </div>

        <div class="glass p-6 rounded-[var(--radius-3xl)] border-white/5 relative overflow-hidden group">
            <div class="absolute -bottom-6 -right-4 font-black text-8xl text-white opacity-[0.03] group-hover:opacity-[0.08] group-hover:text-[#00f2a1] transition-all duration-500 pointer-events-none select-none">02</div>
            <div class="flex items-center justify-between mb-4 relative z-10">
                <div class="w-10 h-10 rounded-xl bg-[#00f2a1]/10 flex items-center justify-center text-[#00f2a1] group-hover:shadow-[0_0_20px_#00f2a144] transition-all">
                    <i data-lucide="check-circle" class="w-5 h-5"></i>
                </div>
                <span class="text-[9px] font-black text-[var(--text-muted)] uppercase tracking-widest">Completados</span>
            </div>
            <h3 id="tracking-metric-completados" class="text-3xl font-black text-[#00f2a1] relative z-10">--</h3>
            <div class="mt-4 h-1 w-12 bg-[#00f2a1]/20 rounded-full group-hover:w-full transition-all duration-700 relative z-10"></div>
        </div>

        <div class="glass p-6 rounded-[var(--radius-3xl)] border-white/5 relative overflow-hidden group">
            <div class="absolute -bottom-6 -right-4 font-black text-8xl text-white opacity-[0.03] group-hover:opacity-[0.08] group-hover:text-[#38bdf8] transition-all duration-500 pointer-events-none select-none">03</div>
            <div class="flex items-center justify-between mb-4 relative z-10">
                <div class="w-10 h-10 rounded-xl bg-[#38bdf8]/10 flex items-center justify-center text-[#38bdf8] group-hover:shadow-[0_0_20px_#38bdf844] transition-all">
                    <i data-lucide="play-circle" class="w-5 h-5"></i>
                </div>
                <span class="text-[9px] font-black text-[var(--text-muted)] uppercase tracking-widest">Estudiando</span>
            </div>
            <h3 id="tracking-metric-progreso" class="text-3xl font-black text-[#38bdf8] relative z-10">--</h3>
            <div class="mt-4 h-1 w-12 bg-[#38bdf8]/20 rounded-full group-hover:w-full transition-all duration-700 relative z-10"></div>
        </div>

        <div class="glass p-6 rounded-[var(--radius-3xl)] border-white/5 relative overflow-hidden group">
            <div class="absolute -bottom-6 -right-4 font-black text-8xl text-white opacity-[0.03] group-hover:opacity-[0.08] group-hover:text-[#fbbf24] transition-all duration-500 pointer-events-none select-none">04</div>
            <div class="flex items-center justify-between mb-4 relative z-10">
                <div class="w-10 h-10 rounded-xl bg-[#fbbf24]/10 flex items-center justify-center text-[#fbbf24] group-hover:shadow-[0_0_20px_#fbbf2444] transition-all">
                    <i data-lucide="database" class="w-5 h-5"></i>
                </div>
                <span class="text-[9px] font-black text-[var(--text-muted)] uppercase tracking-widest">Almacén</span>
            </div>
            <h3 id="tracking-metric-storage" class="text-3xl font-black text-white relative z-10">-- <span class="text-sm font-bold opacity-30">GB</span></h3>
            <div class="mt-4 h-1 w-12 bg-[#fbbf24]/20 rounded-full group-hover:w-full transition-all duration-700 relative z-10"></div>
        </div>
    </div>

    <!-- Tracking Progress Table -->
    <div class="glass rounded-[var(--radius-3xl)] overflow-hidden border border-white/5">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-white/[.02] border-b border-white/5">
                        <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)]">Curso</th>
                        <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)]">Escuela</th>
                        <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)]">Progreso</th>
                        <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)]">Visto</th>
                        <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)]">Estado</th>
                        <th class="px-6 py-5 text-[10px] font-black uppercase tracking-widest text-[var(--text-muted)] text-center">Acción</th>
                    </tr>
                </thead>
                <tbody id="trackingTableBody" class="divide-y divide-white/[.02]">
                    <!-- Content via JS -->
                </tbody>
            </table>
        </div>
        <div id="trackingEmpty" class="hidden py-12 text-center">
            <p class="text-[var(--text-muted)] text-sm italic font-medium">No hay datos de tracking disponibles.</p>
        </div>
    </div>
</section>
