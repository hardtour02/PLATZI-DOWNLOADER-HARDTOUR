<section id="view-registro" class="view-section">
            <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div>
                    <h2 class="text-3xl font-black mb-2">Historial de Sistema</h2>
                    <p class="text-slate-500 text-sm">Bitácora de descargas y registro de envíos.</p>
                </div>
                <!-- Mini Tab Controller -->
                <div class="flex bg-black/40 p-1 rounded-xl border border-white/5">
                    <button onclick="switchRegTab('bitacora')" id="tab-bitacora"
                        class="tab-btn active px-6 py-2 rounded-lg text-xs font-bold transition">Bitácora</button>
                    <button onclick="switchRegTab('drive')" id="tab-drive"
                        class="tab-btn px-6 py-2 rounded-lg text-xs font-bold transition text-slate-500 hover:text-white">Log
                        Drive</button>
                    <button onclick="switchRegTab('envios')" id="tab-envios"
                        class="tab-btn px-6 py-2 rounded-lg text-xs font-bold transition text-slate-500 hover:text-white">Envíos
                        Drive</button>
                </div>
            </div>

            <style>
                .tab-btn.active {
                    background: #00f2a1;
                    color: #000;
                    box-shadow: 0 4px 12px rgba(0, 242, 161, 0.2);
                }
            </style>

            <!-- TAB: LOG DRIVE -->
            <div id="reg-tab-drive" class="reg-tab-content hidden">
                <div class="bg-[#1a1a1a] border border-white/10 rounded-2xl overflow-hidden shadow-2xl">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th style="width: 180px;">Fecha / Hora</th>
                                <th>Curso / Acción</th>
                                <th style="width: 100px;" class="text-center">Estado</th>
                            </tr>
                        </thead>
                        <tbody id="driveLogBody"></tbody>
                    </table>
                    <div id="driveLogEmpty" class="hidden p-20 text-center text-slate-500">
                        <i data-lucide="cloud-upload" class="w-12 h-12 mx-auto mb-4 opacity-10"></i>
                        <p class="text-sm">No hay actividad de Drive registrada.</p>
                    </div>
                </div>
            </div>

            <!-- TAB: BITACORA -->
            <div id="reg-tab-bitacora" class="reg-tab-content">
                <div class="bg-[#1a1a1a] border border-white/10 rounded-2xl overflow-hidden shadow-2xl">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th style="width: 180px;">Fecha / Hora</th>
                                <th style="width: 120px;">Evento</th>
                                <th>Mensaje</th>
                                <th style="width: 100px;" class="text-center">Estado</th>
                            </tr>
                        </thead>
                        <tbody id="activityLogBody"></tbody>
                    </table>
                    <div id="activityEmpty" class="hidden p-20 text-center text-slate-500">
                        <i data-lucide="activity" class="w-12 h-12 mx-auto mb-4 opacity-10"></i>
                        <p class="text-sm">No hay actividad registrada recientemente.</p>
                    </div>
                </div>
            </div>

            <!-- TAB: ENVIOS -->
            <div id="reg-tab-envios" class="reg-tab-content hidden">
                <div class="flex flex-col gap-6 mb-10">
                    <div class="relative w-full">
                        <i data-lucide="search"
                            class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-500 w-5 h-5"></i>
                        <input id="regSearchInput" type="text" placeholder="Buscar por email o curso..."
                            class="search-bar pl-14 pr-12 text-sm" oninput="filterSharingLogs()">
                        <button id="regSearchClearBtn" onclick="clearRegSearch()"
                            class="hidden absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-white transition p-1.5 rounded-full hover:bg-white/10">
                            <i data-lucide="x" class="w-4 h-4"></i>
                        </button>
                    </div>
                </div>

                <div class="bg-[#1a1a1a] border border-white/10 rounded-2xl overflow-hidden shadow-2xl">
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>Curso</th>
                                <th>Email Destinatario</th>
                                <th class="text-center">Fecha de Envío</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="sharingLogBody"></tbody>
                    </table>
                    <div id="sharingEmpty" class="hidden p-20 text-center text-slate-500">
                        <i data-lucide="inbox" class="w-12 h-12 mx-auto mb-4 opacity-20"></i>
                        <p class="text-sm">No hay registros de envíos todavía.</p>
                    </div>
                </div>
            </div>
        </section>